.grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.info-box{border:1px solid #aaa;padding:6px 10px}
.info-lbl{font-size:10px;color:#888;display:block}
.goal-box{border:1px solid #aaa;padding:8px;min-height:64px;white-space:pre-wrap;font-size:11px}
.legend{font-size:10px;color:#666;margin-bottom:6px}
.sig-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-top:16px}
.sig-box{border-bottom:1px solid #333;padding-bottom:4px;min-height:36px}
