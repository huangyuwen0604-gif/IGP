<div class="goal-box">${suggest}</div>
<div class="sig-row">
  <div><div class="sig-box"></div><div class="sig-lbl">教師簽名</div></div>
  <div><div class="sig-box"></div><div class="sig-lbl">家長簽名</div></div>
