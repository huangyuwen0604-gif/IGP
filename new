<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IGP 個別輔導計畫填寫工具｜勝利國中資優班</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #ffffff;
  --bg2: #f7f6f3;
  --bg3: #f0ede8;
  --text: #1a1a18;
  --text2: #5f5e5a;
  --text3: #888780;
  --border: rgba(0,0,0,0.12);
  --border2: rgba(0,0,0,0.22);
  --blue-bg: #e6f1fb;
  --blue-text: #0c447c;
  --green-bg: #eaf3de;
  --green-text: #27500a;
  --amber-bg: #faeeda;
  --amber-text: #633806;
  --red-bg: #fcebeb;
  --red-text: #791f1f;
  --pink-bg: #fbeaf0;
  --pink-text: #72243e;
  --gray-bg: #f1efe8;
  --radius: 8px;
  --radius-lg: 12px;
}

@media (prefers-color-scheme: dark) {
  :root {
    --bg: #1e1e1c;
    --bg2: #2a2a28;
    --bg3: #333331;
    --text: #f0ede8;
    --text2: #b4b2a9;
    --text3: #888780;
    --border: rgba(255,255,255,0.12);
    --border2: rgba(255,255,255,0.22);
    --blue-bg: #0c2840;
    --blue-text: #85b7eb;
    --green-bg: #173404;
    --green-text: #c0dd97;
    --amber-bg: #412402;
    --amber-text: #fac775;
    --red-bg: #501313;
    --red-text: #f09595;
    --pink-bg: #4b1528;
    --pink-text: #ed93b1;
    --gray-bg: #2c2c2a;
  }
}

body {
  font-family: 'Microsoft JhengHei', 'PingFang TC', 'Noto Sans TC', sans-serif;
  background: var(--bg3);
  color: var(--text);
  font-size: 14px;
  min-height: 100vh;
}

.page-header {
  background: var(--bg);
  border-bottom: 0.5px solid var(--border);
  padding: 1rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 12px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo {
  width: 36px; height: 36px;
  border-radius: var(--radius);
  background: var(--blue-bg);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
}

.page-header h1 { font-size: 16px; font-weight: 500; }
.page-header p { font-size: 12px; color: var(--text2); margin-top: 1px; }

.badge {
  font-size: 11px; padding: 3px 10px;
  border-radius: 20px;
  background: var(--blue-bg); color: var(--blue-text);
  font-weight: 500; white-space: nowrap; margin-left: auto;
}

.container { max-width: 960px; margin: 0 auto; padding: 1.5rem 1rem; }

.step-nav {
  display: flex; gap: 6px; margin-bottom: 1.25rem; flex-wrap: wrap;
  background: var(--bg); border-radius: var(--radius-lg);
  padding: 10px 14px; border: 0.5px solid var(--border);
}

.step-btn {
  font-size: 13px; padding: 6px 14px;
  border: 0.5px solid var(--border2);
  border-radius: 20px;
  background: transparent; color: var(--text2);
  cursor: pointer; transition: all .15s;
  font-family: inherit;
}
.step-btn.active {
  background: var(--text); color: var(--bg);
  border-color: var(--text); font-weight: 500;
}
.step-btn:hover:not(.active) { background: var(--bg2); }
.step-btn.done { border-color: var(--green-text); color: var(--green-text); }

.card {
  background: var(--bg);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  margin-bottom: 1rem;
}

.section-title {
  font-size: 12px; font-weight: 500; color: var(--text3);
  text-transform: uppercase; letter-spacing: .05em;
  margin-bottom: .875rem; padding-bottom: 8px;
  border-bottom: 0.5px solid var(--border);
}

.form-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px; margin-bottom: 1rem;
}

.field label {
  font-size: 12px; color: var(--text2);
  display: block; margin-bottom: 4px; font-weight: 500;
}

.field select,
.field input[type="text"],
.field input[type="date"],
.field textarea {
  width: 100%; font-size: 13px;
  padding: 7px 10px;
  border: 0.5px solid var(--border2);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--text);
  font-family: inherit;
  transition: border-color .15s;
}

.field select:focus,
.field input:focus,
.field textarea:focus {
  outline: none;
  border-color: var(--blue-text);
  box-shadow: 0 0 0 3px rgba(55,138,221,0.15);
}

.field textarea { min-height: 80px; resize: vertical; line-height: 1.6; }

.summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 10px; margin-bottom: 1rem;
}

.metric {
  background: var(--bg2);
  border-radius: var(--radius);
  padding: .75rem 1rem;
}
.metric-val { font-size: 20px; font-weight: 500; }
.metric-lbl { font-size: 11px; color: var(--text2); margin-top: 2px; }

.info-row {
  display: grid; grid-template-columns: 120px 1fr;
  gap: 6px; align-items: center;
  font-size: 13px; padding: 7px 0;
  border-bottom: 0.5px solid var(--border);
}
.info-row:last-child { border-bottom: none; }
.info-label { color: var(--text2); font-weight: 500; }

.notice {
  font-size: 12px; color: var(--text2);
  background: var(--blue-bg); color: var(--blue-text);
  border-radius: var(--radius);
  padding: 8px 12px; margin-bottom: 1rem;
  line-height: 1.5;
}

.unit-table {
  width: 100%; border-collapse: collapse;
  font-size: 13px; table-layout: fixed;
}
.unit-table th {
  background: var(--bg2); padding: 8px 10px;
  text-align: left; font-weight: 500;
  font-size: 12px; color: var(--text2);
  border: 0.5px solid var(--border);
  position: sticky; top: 56px;
}
.unit-table td {
  padding: 7px 10px;
  border: 0.5px solid var(--border);
  vertical-align: top; line-height: 1.5;
}
.unit-table tr:hover td { background: var(--bg2); }

.adj-tags, .eval-tags { display: flex; flex-wrap: wrap; gap: 4px; }

.adj-tag {
  font-size: 11px; padding: 2px 8px;
  border-radius: 20px;
  background: var(--blue-bg); color: var(--blue-text);
  white-space: nowrap;
}
.eval-tag {
  font-size: 11px; padding: 2px 8px;
  border-radius: 20px;
  background: var(--bg2); color: var(--text2);
  border: 0.5px solid var(--border2);
  white-space: nowrap;
}

.score-select {
  width: 100%; font-size: 12px;
  padding: 5px 7px;
  border: 0.5px solid var(--border2);
  border-radius: var(--radius);
  background: var(--bg); color: var(--text);
  font-family: inherit; cursor: pointer;
}
.score-select.s-top  { background: var(--green-bg); color: var(--green-text); border-color: var(--green-text); }
.score-select.s-good { background: var(--blue-bg);  color: var(--blue-text);  border-color: var(--blue-text); }
.score-select.s-fair { background: var(--amber-bg); color: var(--amber-text); border-color: var(--amber-text); }
.score-select.s-mid  { background: var(--pink-bg);  color: var(--pink-text);  border-color: var(--pink-text); }
.score-select.s-low  { background: var(--red-bg);   color: var(--red-text);   border-color: var(--red-text); }
.score-select.s-weak { background: var(--red-bg);   color: var(--red-text);   border-color: var(--red-text); font-weight:500; }

.actions {
  display: flex; gap: 8px; margin-top: 1.25rem; flex-wrap: wrap;
  align-items: center;
}

.btn-pri {
  padding: 8px 20px;
  border-radius: var(--radius);
  background: var(--text); color: var(--bg);
  border: none; font-size: 13px;
  cursor: pointer; font-family: inherit;
  transition: opacity .15s;
}
.btn-pri:hover { opacity: .85; }

.btn-sec {
  padding: 8px 20px;
  border-radius: var(--radius);
  background: transparent; color: var(--text2);
  border: 0.5px solid var(--border2);
  font-size: 13px; cursor: pointer; font-family: inherit;
}
.btn-sec:hover { background: var(--bg2); }

.btn-outline {
  padding: 8px 20px;
  border-radius: var(--radius);
  background: transparent; color: var(--blue-text);
  border: 0.5px solid var(--blue-text);
  font-size: 13px; cursor: pointer; font-family: inherit;
}
.btn-outline:hover { background: var(--blue-bg); }

.progress-bar {
  height: 3px; background: var(--bg3);
  border-radius: 2px; margin-bottom: 1.25rem; overflow: hidden;
}
.progress-fill {
  height: 100%; background: var(--blue-text);
  border-radius: 2px; transition: width .3s ease;
}

.score-summary {
  display: flex; gap: 8px; flex-wrap: wrap; margin-top: .75rem;
}
.score-pill {
  font-size: 12px; padding: 3px 10px;
  border-radius: 20px; font-weight: 500;
}

.teach-cell {
  font-size: 12px; color: var(--text2);
  line-height: 1.55; max-height: 90px;
  overflow-y: auto;
}

/* Print styles */
@media print {
  body { background: white; font-size: 12px; }
  .page-header, .step-nav, .actions, .progress-bar, .notice { display: none !important; }
  .card { border: 1px solid #ccc; margin-bottom: 8px; page-break-inside: avoid; }
  .container { padding: 0; max-width: 100%; }
  .unit-table th { background: #f0f0f0 !important; }
  .score-select { border: 1px solid #ccc !important; background: white !important; }
}

@media (max-width: 600px) {
  .page-header h1 { font-size: 14px; }
  .container { padding: 1rem .75rem; }
  .card { padding: 1rem; }
  .form-row { grid-template-columns: 1fr; }
  .unit-table { font-size: 12px; }
  .unit-table th, .unit-table td { padding: 5px 6px; }
}
</style>
</head>
<body>

<header class="page-header">
  <div class="logo">📋</div>
  <div>
    <h1>IGP 個別輔導計畫填寫工具</h1>
    <p>新竹縣立勝利國民中學・114學年度第2學期・資賦優異班</p>
  </div>
  <span class="badge">114-2 數理資優</span>
</header>

<div class="container">

  <div class="progress-bar">
    <div class="progress-fill" id="progressFill" style="width:25%"></div>
  </div>

  <nav class="step-nav">
    <button class="step-btn active" id="nav0" onclick="showStep(0)">① 選擇科目</button>
    <button class="step-btn"        id="nav1" onclick="showStep(1)">② 基本資訊</button>
    <button class="step-btn"        id="nav2" onclick="showStep(2)">③ 週次單元</button>
    <button class="step-btn"        id="nav3" onclick="showStep(3)">④ 評量結果</button>
  </nav>

  <!-- STEP 0: 選擇科目 -->
  <div id="step0">
    <div class="card">
      <div class="section-title">選擇課程與學生</div>
      <div class="form-row">
        <div class="field">
          <label>年級篩選</label>
          <select id="selGrade" onchange="filterSubjects()">
            <option value="">全部年級</option>
            <option value="七年級">七年級</option>
            <option value="八年級">八年級</option>
            <option value="九年級">九年級</option>
          </select>
        </div>
        <div class="field">
          <label>課程科目 <span style="color:red">*</span></label>
          <select id="selSubject" onchange="onSubjectChange()">
            <option value="">請選擇科目...</option>
          </select>
        </div>
        <div class="field">
          <label>學生姓名 <span style="color:red">*</span></label>
          <input type="text" id="studentName" placeholder="請輸入學生姓名"/>
        </div>
        <div class="field">
          <label>學年度學期</label>
          <input type="text" id="semester" value="114學年度第2學期" />
        </div>
      </div>

      <div id="subjPreview" style="display:none">
        <div class="summary-grid">
          <div class="metric">
            <div class="metric-val" id="prev-hours">—</div>
            <div class="metric-lbl">節數 / 週</div>
          </div>
          <div class="metric">
            <div class="metric-val" id="prev-units">—</div>
            <div class="metric-lbl">教學單元數</div>
          </div>
          <div class="metric">
            <div class="metric-val" id="prev-type">—</div>
            <div class="metric-lbl">課程類型</div>
          </div>
          <div class="metric">
            <div class="metric-val" id="prev-grade">—</div>
            <div class="metric-lbl">開課年級</div>
          </div>
        </div>
      </div>

      <div class="actions">
        <button class="btn-pri" onclick="goStep1()">下一步：確認基本資訊 →</button>
      </div>
    </div>
  </div>

  <!-- STEP 1: 基本資訊 -->
  <div id="step1" style="display:none">
    <div class="card">
      <div class="section-title">課程基本資訊</div>
      <div class="notice">以下資訊已從課程計畫自動帶入，請確認後可直接修改。</div>
      <div id="infoDisplay"></div>
    </div>

    <div class="card">
      <div class="section-title">學年目標（核心素養 / 學習重點）</div>
      <div class="field" style="margin-bottom:.75rem">
        <label>學年目標（建議填寫 3–5 條，整學期的學習總目標）</label>
        <textarea id="annualGoal" rows="5"
          placeholder="例如：&#10;1. 能熟練二元一次聯立方程式的解法，並應用於日常情境。&#10;2. 能理解直角坐標系的意義，並描繪二元一次方程式的圖形。&#10;3. 能掌握比例式、正反比的概念與應用。"></textarea>
      </div>
      <div class="field">
        <label>核心素養（參考課程計畫，可直接複製）</label>
        <textarea id="coreCompetency" rows="3"
          placeholder="例如：A2.系統思考與問題解決、B1.符號運用與溝通表達、C2.人際關係與團隊合作"></textarea>
      </div>
    </div>

    <div class="actions">
      <button class="btn-sec" onclick="showStep(0)">← 上一步</button>
      <button class="btn-pri" onclick="showStep(2)">下一步：週次單元 →</button>
    </div>
  </div>

  <!-- STEP 2: 週次單元 -->
  <div id="step2" style="display:none">
    <div class="card">
      <div class="section-title">週次教學單元</div>
      <div class="notice">單元資訊已從課程計畫自動帶入。單元名稱欄位可直接點擊編輯。</div>
      <div style="overflow-x:auto">
        <table class="unit-table" id="unitTable">
          <thead>
            <tr>
              <th style="width:60px">週次</th>
              <th style="width:150px">單元名稱</th>
              <th>教學重點</th>
              <th style="width:120px">學習內容調整</th>
              <th style="width:120px">評量方式</th>
            </tr>
          </thead>
          <tbody id="unitBody"></tbody>
        </table>
      </div>
    </div>

    <div class="actions">
      <button class="btn-sec" onclick="showStep(1)">← 上一步</button>
      <button class="btn-pri" onclick="showStep(3)">下一步：評量結果 →</button>
    </div>
  </div>

  <!-- STEP 3: 評量結果 -->
  <div id="step3" style="display:none">
    <div class="card">
      <div class="section-title">評量結果登錄</div>
      <div class="notice">
        評量結果對應說明：
        <strong>特優</strong> 95–100%&ensp;｜&ensp;<strong>優</strong> 85–94%&ensp;｜&ensp;<strong>良</strong> 70–84%&ensp;｜&ensp;<strong>中等</strong> 55–69%&ensp;｜&ensp;<strong>中下</strong> 40–54%&ensp;｜&ensp;<strong>待加強</strong> 39% 以下
      </div>
      <div style="overflow-x:auto">
        <table class="unit-table" id="scoreTable">
          <thead>
            <tr>
              <th style="width:60px">週次</th>
              <th style="width:160px">單元名稱</th>
              <th style="width:120px">評量方式</th>
              <th style="width:110px">評量日期</th>
              <th style="width:130px">評量結果</th>
            </tr>
          </thead>
          <tbody id="scoreBody"></tbody>
        </table>
      </div>

      <div id="scoreSummaryWrap" style="margin-top:1rem;display:none">
        <div class="section-title" style="margin-top:.5rem">評量統計</div>
        <div class="score-summary" id="scoreSummary"></div>
      </div>
    </div>

    <div class="card">
      <div class="section-title">整體評語與建議</div>
      <div class="form-row">
        <div class="field">
          <label>整體學習表現評語</label>
          <textarea id="overallComment" rows="4"
            placeholder="請填寫學生本學期整體學習表現..."></textarea>
        </div>
        <div class="field">
          <label>教師建議</label>
          <textarea id="teacherSuggestion" rows="4"
            placeholder="請填寫對學生下學期的建議與期望..."></textarea>
        </div>
      </div>
    </div>

    <div class="actions">
      <button class="btn-sec" onclick="showStep(2)">← 上一步</button>
      <button class="btn-outline" onclick="printIGP()">🖨 列印 / 匯出 PDF</button>
      <button class="btn-pri" onclick="exportData()">💾 儲存資料（JSON）</button>
    </div>
  </div>

</div><!-- /container -->

<!-- PRINT VIEW (hidden, used for print only) -->
<div id="printView" style="display:none"></div>

<script>
// ─── 課程資料 ─────────────────────────────────────────────
const CURRICULUM = [
  {
    id:"數學/七年級(文津)", name:"數學", grade:"七年級", hours:"4",
    teacher:"（待定）", type:"領域學習課程",
    coreComp:"A2.系統思考與問題解決、B1.符號運用與溝通表達、B2.科技資訊與媒體素養、C2.人際關係與團隊合作",
    units:[
      {w:"1-2",  u:"1-1 二元一次方程式",          t:"1. 能由具體情境用x、y符號列出二元一次式。\n2. 能合併/化簡算式中相同的文字符號、常數。\n3. 能以代入法或枚舉法求二元一次方程式的解。",                                                                          a:["加深"],           e:["紙筆測驗","口語評量"]},
      {w:"3",    u:"1-2 解二元一次聯立方程式",     t:"1. 了解二元一次方程式解的意義。\n2. 能熟練使用代入消去法、加減消去法求解。\n3. 二元一次不定方程補充。\n4. 三元一次方程組探討（加廣）。",                                                                       a:["加深","加廣"],    e:["紙筆測驗","口語評量"]},
      {w:"4-5",  u:"1-3 應用問題",                 t:"1. 能運用二元一次聯立方程式解決日常生活問題，並判別解是否合乎題意。\n2. 行列式解二元一次方程組（加廣）。\n3. 特殊聯立方程式（加廣）。",                                                                         a:["加深","加廣"],    e:["紙筆測驗","實作評量"]},
      {w:"6-7",  u:"2-1 直角坐標平面",             t:"1. 認識直角坐標、坐標表示法。\n2. 介紹四個象限上的符號規則。\n3. 能判斷一個點位於哪一個象限。",                                                                                                                   a:["統整教學主題"],   e:["紙筆測驗","實作評量"]},
      {w:"8-9",  u:"2-2 二元一次方程式的圖形",     t:"1. 能在直角坐標平面上描繪二元一次方程式的圖形。\n2. 認識斜率，直線方程式各種求法（斜截式、點斜式、截距式、兩點式）（加廣）。",                                                                                 a:["加深","加廣"],    e:["紙筆測驗","實作評量"]},
