  <div class="info-box"><span class="info-lbl">課程名稱</span>${s.name}</div>
  <div class="info-box"><span class="info-lbl">教學年級</span>${s.grade}</div>
  <div class="info-box"><span class="info-lbl">課程類型</span>${s.type||'—'}</div>
  <div class="info-box"><span class="info-lbl">教學節數/週</span>${s.hours||'—'} 節</div>
  <div class="info-box"><span class="info-lbl">教學者</span>${s.teacher||'（待定）'}</div>
</div>
<h3>核心素養</h3>
