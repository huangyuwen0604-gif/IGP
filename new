h2{font-size:15px;text-align:center;margin-bottom:4px;font-weight:600}
h3{font-size:13px;margin:12px 0 4px;font-weight:600;border-left:3px solid #378add;padding-left:6px}
p.sub{text-align:center;font-size:11px;color:#666;margin-bottom:10px}
table{width:100%;border-collapse:collapse;margin-bottom:10px}
th,td{border:1px solid #aaa;padding:5px 8px;text-align:left;vertical-align:top;font-size:11px}
