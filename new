  <thead><tr><th style="width:50px">週次</th><th style="width:130px">課程內容</th><th style="width:100px">評量方式</th><th style="width:80px">評量日期</th><th style="width:80px">評量結果</th></tr></thead>
  <tbody>${rows}</tbody>
