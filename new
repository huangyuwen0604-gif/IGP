  populateSubjects(document.getElementById('selGrade').value);
  document.getElementById('subjPreview').style.display = 'none';
  currentSubject = null;
}

function onSubjectChange() {
  const idx = document.getElementById('selSubject').value;
  if (idx === "" || idx === null) {
    document.getElementById('subjPreview').style.display = 'none';
    return;
  }
  currentSubject = CURRICULUM[+idx];
  scores = {}; evalDates = {};
  document.getElementById('prev-hours').textContent  = currentSubject.hours || '—';
  document.getElementById('prev-units').textContent  = currentSubject.units.length;
  document.getElementById('prev-type').textContent   = (currentSubject.type||'—').replace('課程','');
  document.getElementById('prev-grade').textContent  = currentSubject.grade || '—';
  document.getElementById('subjPreview').style.display = 'block';
}

// ─── 步驟控制 ────────────────────────────────────────────
function showStep(n) {
  [0,1,2,3].forEach(i => {
    document.getElementById('step'+i).style.display = i===n ? 'block' : 'none';
    const btn = document.getElementById('nav'+i);
    btn.classList.toggle('active', i===n);
  });
  document.getElementById('progressFill').style.width = ((n+1)/4*100) + '%';
  currentStep = n;
  if (n===2 && currentSubject) buildUnitTable();
  if (n===3 && currentSubject) buildScoreTable();
  window.scrollTo({top:0, behavior:'smooth'});
}

function goStep1() {
  if (!currentSubject) { alert('請先選擇科目！'); return; }
  if (!document.getElementById('studentName').value.trim()) { alert('請輸入學生姓名！'); return; }
  buildInfoDisplay();
  // Pre-fill core competency
  if (!document.getElementById('coreCompetency').value && currentSubject.coreComp) {
    document.getElementById('coreCompetency').value = currentSubject.coreComp;
  }
  showStep(1);
}

// ─── 資訊顯示 ────────────────────────────────────────────
function buildInfoDisplay() {
  const s = currentSubject;
  const student = document.getElementById('studentName').value.trim();
  const semester = document.getElementById('semester').value;
  const typeLabel = {
    '領域學習課程': '■ 領域學習課程',
    '特殊需求課程': '■ 特殊需求課程',
    '獨立研究課程': '■ 獨立研究課程'
  }[s.type] || s.type;

  const rows = [
    ['學年度學期', semester],
    ['學生姓名',   student],
    ['課程名稱',   s.name],
    ['開課年級',   s.grade],
    ['教學節數/週', (s.hours||'—') + ' 節'],
    ['教學者',     s.teacher],
    ['課程類型',   typeLabel],
  ];
  document.getElementById('infoDisplay').innerHTML =
    rows.map(r => `<div class="info-row"><span class="info-label">${r[0]}</span><span class="info-val">${r[1]}</span></div>`).join('');
}

// ─── 週次單元表格 ─────────────────────────────────────────
function buildUnitTable() {
  const tbody = document.getElementById('unitBody');
  tbody.innerHTML = currentSubject.units.map((u, i) => `
    <tr>
      <td style="font-weight:500;color:var(--text2);white-space:nowrap">${u.w}</td>
      <td><div contenteditable="true" style="outline:none;font-size:13px;min-height:16px" data-unit="${i}">${u.u.replace(/\n/g,'<br>')}</div></td>
      <td><div class="teach-cell">${u.t.replace(/\n/g,'<br>')}</div></td>
      <td><div class="adj-tags">${(u.a||[]).map(a=>`<span class="adj-tag">${a}</span>`).join('') || '<span style="color:var(--text3);font-size:12px">—</span>'}</div></td>
      <td><div class="eval-tags">${(u.e||[]).map(e=>`<span class="eval-tag">${e}</span>`).join('') || '<span style="color:var(--text3);font-size:12px">—</span>'}</div></td>
    </tr>`).join('');
}

// ─── 評量結果表格 ─────────────────────────────────────────
function buildScoreTable() {
  const tbody = document.getElementById('scoreBody');
  tbody.innerHTML = currentSubject.units.map((u, i) => `
    <tr>
      <td style="font-weight:500;color:var(--text2);white-space:nowrap">${u.w}</td>
      <td style="font-size:13px">${u.u.replace(/\n/g,' ')}</td>
      <td><div class="eval-tags">${(u.e||[]).map(e=>`<span class="eval-tag">${e}</span>`).join('')}</div></td>
      <td>
        <input type="date" id="date_${i}"
          style="width:100%;font-size:12px;padding:4px 6px;border:0.5px solid var(--border2);border-radius:var(--radius);background:var(--bg);color:var(--text);font-family:inherit"
          onchange="evalDates[${i}]=this.value" ${evalDates[i]?'value="'+evalDates[i]+'"':''} />
      </td>
      <td>
        <select class="score-select ${SCORE_CLS[scores[i]||0]}" id="score_${i}" onchange="updateScore(${i},this)">
          ${SCORES.map((sc,si)=>`<option value="${si}" ${(scores[i]||0)===si?'selected':''}>${sc||'請選擇...'}</option>`).join('')}
        </select>
      </td>
    </tr>`).join('');
  updateSummary();
}

function updateScore(idx, sel) {
  const si = +sel.value;
  sel.className = 'score-select ' + (SCORE_CLS[si]||'');
  scores[idx] = si;
  updateSummary();
}

function updateSummary() {
  const counts = [0,0,0,0,0,0,0];
  Object.values(scores).forEach(v => { if(v) counts[v]++; });
  const total = Object.values(scores).filter(v=>v>0).length;
  const wrap = document.getElementById('scoreSummaryWrap');
  if (total === 0) { wrap.style.display='none'; return; }
  wrap.style.display='block';
  const labels = ['','特優','優','良','中等','中下','待加強'];
  document.getElementById('scoreSummary').innerHTML =
    counts.map((c,i)=> i>0&&c>0
      ? `<span class="score-pill" style="background:${SCORE_BG[i]};color:${SCORE_PILL[i]}">${labels[i]}：${c} 項</span>`
      : '').join('');
}

// ─── 列印 ────────────────────────────────────────────────
function printIGP() {
  if (!currentSubject) { alert('尚未選擇科目'); return; }
  const student  = document.getElementById('studentName').value.trim() || '__________';
  const semester = document.getElementById('semester').value;
  const s        = currentSubject;
  const goal     = document.getElementById('annualGoal').value || '（未填）';
  const core     = document.getElementById('coreCompetency').value || s.coreComp || '（未填）';
  const comment  = document.getElementById('overallComment').value || '（未填）';
  const suggest  = document.getElementById('teacherSuggestion').value || '（未填）';

  const scoreLabels = ['','特優','優','良','中等','中下','待加強'];

  const rows = s.units.map((u,i) => {
