// ─── 儲存 JSON ───────────────────────────────────────────
function exportData() {
  if (!currentSubject) { alert('尚未選擇科目'); return; }
  const student  = document.getElementById('studentName').value.trim();
  const semester = document.getElementById('semester').value;
  const s = currentSubject;

  const payload = {
    exportedAt: new Date().toISOString(),
    semester,
    student,
    subject: s.id,
    courseName: s.name,
    grade: s.grade,
    teacher: s.teacher,
    type: s.type,
    annualGoal: document.getElementById('annualGoal').value,
    coreCompetency: document.getElementById('coreCompetency').value,
    overallComment: document.getElementById('overallComment').value,
    teacherSuggestion: document.getElementById('teacherSuggestion').value,
    units: s.units.map((u,i)=>({
      week: u.w,
      unit: u.u,
      adjustment: u.a,
      evalMethods: u.e,
      evalDate: evalDates[i]||'',
      score: scores[i]||0,
      scoreLabel: SCORES[scores[i]||0]||''
    }))
  };

  const blob = new Blob([JSON.stringify(payload, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `IGP_${student}_${s.name}_${semester}.json`;
  a.click();
}

// ─── 啟動 ────────────────────────────────────────────────
populateSubjects();
</script>
</body>
</html>
